{
  "$schema": "../schema/datagen.schema.json",
  "rows": 200,
  "output": {
    "type": "file",
    "file": {
      "format": "csv",
      "options": {
        "header": true,
        "line_ending": "LF"
      }
    }
  },
  "fields": [
    {
      "name": "email",
      "generator": "email",
      "config": {
        "languages": ["English"],
        "domains": ["example.com"]
      },
      "group": "person:Group1",
      "unique": true
    },
    {
      "name": "id",
      "generator": "sequence",
      "config": {
        "start": 1,
        "end": 100000000,
        "step": 1,
        "circle": false
      }
    },
    {
      "name": "uuid",
      "generator": "uuid",
      "config": {
        "include_hyphens": true
      }
    },
    {
      "name": "first_name",
      "generator": "first_name",
      "config": {
        "languages": ["English"],
        "genders": ["M", "F"],
        "use_translation": false
      },
      "group": "person:Group1"
    },
    {
      "name": "last_name",
      "generator": "last_name",
      "config": {
        "languages": ["English"],
        "use_translation": false
      },
      "group": "person:Group1"
    },
    {
      "name": "age",
      "generator": "integer",
      "config": {
        "start": 18,
        "end": 85
      }
    },
    {
      "name": "gender",
      "generator": "gender",
      "config": {
        "languages": ["English"]
      },
      "group": "person:Group1"
    },
    {
      "name": "phone_number",
      "generator": "phone_number",
      "config": {
        "regions": ["United States"],
        "is_international": false,
        "include_delimiters": true
      },
      "group": "person:Group1"
    },
    {
      "name": "notes",
      "generator": "text",
      "config": {
        "number_of_chars_start": 20,
        "number_of_chars_end": 200
      },
      "default_value": {
        "enabled": true,
        "value": "N/A",
        "percentage": 10
      },
      "null_value": {
        "enabled": true,
        "percentage": 10
      }
    },
    {
      "name": "created_at",
      "generator": "datetime",
      "config": {
        "start_date": "2015-01-01",
        "end_date": "2026-12-31",
        "start_time": "00:00:00",
        "end_time": "23:59:59",
        "days_of_week": [
          "Sunday",
          "Monday",
          "Tuesday",
          "Wednesday",
          "Thursday",
          "Friday",
          "Saturday"
        ]
      }
    },
    {
      "name": "salary",
      "generator": "decimal",
      "config": {
        "start": 30000,
        "end": 250000,
        "decimal_places": 2
      }
    },
    {
      "name": "department",
      "generator": "department",
      "config": {
        "languages": ["English"]
      }
    },
    {
      "name": "status",
      "generator": "enum_item",
      "config": {
        "enums": ["active", "inactive", "on_leave"]
      }
    },
    {
      "name": "country",
      "generator": "region",
      "config": {
        "country_codes_standard": "None",
        "languages": ["English"]
      }
    },
    {
      "name": "is_active",
      "generator": "boolean",
      "config": {
        "true_percentage": 80
      }
    }
  ]
}
