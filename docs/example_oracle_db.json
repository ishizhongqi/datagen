{
  "$schema": "../schema/datagen.schema.json",
  "rows": 1000,
  "output": {
    "type": "database",
    "database": {
      "connection": "odbc://DRIVER={Oracle 23 ODBC driver};ServerName=//localhost:1521/FREEPDB1;UserID=user;Password=password;",
      "table": "CUSTOMER_PROFILE",
      "mode": "balanced",
      "write_mode": "append",
      "transaction_mode": "per-batch",
      "error_policy": "stop",
      "advanced": {
        "insert_mode": "insert",
        "batch_size": 2000,
        "queue_size": 2048,
        "threads": 2,
        "rate_limit_rows_per_sec": 20000
      }
    }
  },
  "fields": [
    {
      "name": "EMAIL",
      "generator": "email",
      "config": {
        "languages": ["English"],
        "domains": ["example.com"]
      },
      "group": "person:Group1",
      "unique": true
    },
    {
      "name": "ID",
      "generator": "sequence",
      "config": {
        "start": 1,
        "end": 100000000,
        "step": 1,
        "circle": false
      }
    },
    {
      "name": "UUID",
      "generator": "uuid",
      "config": {
        "include_hyphens": true
      }
    },
    {
      "name": "FIRST_NAME",
      "generator": "first_name",
      "config": {
        "languages": ["English"],
        "genders": ["M", "F"],
        "use_translation": false
      },
      "group": "person:Group1"
    },
    {
      "name": "LAST_NAME",
      "generator": "last_name",
      "config": {
        "languages": ["English"],
        "use_translation": false
      },
      "group": "person:Group1"
    },
    {
      "name": "AGE",
      "generator": "integer",
      "config": {
        "start": 18,
        "end": 85
      }
    },
    {
      "name": "GENDER",
      "generator": "gender",
      "config": {
        "languages": ["English"]
      },
      "group": "person:Group1"
    },
    {
      "name": "PHONE_NUMBER",
      "generator": "phone_number",
      "config": {
        "regions": ["United States"],
        "is_international": false,
        "include_delimiters": true
      },
      "group": "person:Group1"
    },
    {
      "name": "NOTES",
      "generator": "text",
      "config": {
        "number_of_chars_start": 20,
        "number_of_chars_end": 200
      },
      "default_value": {
        "enabled": true,
        "value": "N/A",
        "percentage": 10
      },
      "null_value": {
        "enabled": true,
        "percentage": 10
      }
    },
    {
      "name": "CREATED_AT",
      "generator": "datetime",
      "config": {
        "start_date": "2015-01-01",
        "end_date": "2026-12-31",
        "start_time": "00:00:00",
        "end_time": "23:59:59",
        "days_of_week": [
          "Sunday",
          "Monday",
          "Tuesday",
          "Wednesday",
          "Thursday",
          "Friday",
          "Saturday"
        ]
      }
    },
    {
      "name": "SALARY",
      "generator": "decimal",
      "config": {
        "start": 30000,
        "end": 250000,
        "decimal_places": 2
      }
    },
    {
      "name": "DEPARTMENT",
      "generator": "department",
      "config": {
        "languages": ["English"]
      }
    },
    {
      "name": "STATUS",
      "generator": "enum_item",
      "config": {
        "enums": ["active", "inactive", "on_leave"]
      }
    },
    {
      "name": "COUNTRY",
      "generator": "region",
      "config": {
        "country_codes_standard": "None",
        "languages": ["English"]
      }
    },
    {
      "name": "IS_ACTIVE",
      "generator": "integer",
      "config": {
        "start": 0,
        "end": 1
      }
    }
  ]
}
